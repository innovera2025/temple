NODE_ENV=development
API_PORT=3000
WEB_PORT=5173

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=wat_dev
POSTGRES_USER=wat_dev
POSTGRES_PASSWORD=wat_dev_password
DATABASE_URL=postgresql://wat_dev:wat_dev_password@localhost:5432/wat_dev?schema=public

REDIS_HOST=localhost
REDIS_PORT=6379

# Signs all JWTs (tenant / platform / devotee planes). REQUIRED in production and
# must be a random value of at least 32 characters — the app refuses to boot
# otherwise. In development/test it falls back to a built-in dev-only secret.
# Generate one with:  openssl rand -base64 48
JWT_SECRET=
