NODE_ENV=development
API_PORT=3000
WEB_PORT=5173

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=wat_dev
POSTGRES_USER=wat_dev
POSTGRES_PASSWORD=wat_dev_password
DATABASE_URL=postgresql://wat_dev:wat_dev_password@localhost:5432/wat_dev?schema=public

REDIS_HOST=localhost
REDIS_PORT=6379

# Signs all JWTs (tenant / platform / devotee planes). REQUIRED in production and
# must be a random value of at least 32 characters — the app refuses to boot
# otherwise. In development/test it falls back to a built-in dev-only secret.
# Generate one with:  openssl rand -base64 48
JWT_SECRET=

# ---------------------------------------------------------------------------
# Docker production stack (infra/docker/docker-compose.prod.yml)
# ---------------------------------------------------------------------------
# Inside compose the API/migrate reach Postgres at host `db` (the service name),
# NOT localhost. The DATABASE_URL user must be the POSTGRES_USER superuser so the
# first `prisma migrate deploy` can create the wat_app / wat_migrate roles.
#   DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}?schema=public
#
# Host port the web (nginx) container is published on.
WEB_PUBLIC_PORT=8080
# Baked into the web bundle at build time. "/api" routes through the nginx
# reverse proxy to the API same-origin (no CORS). Use an absolute URL only if the
# API is served on a different origin (then the API must allow that CORS origin).
VITE_API_BASE_URL=/api
# Number of reverse-proxy hops in front of the API (the web/nginx container = 1)
# so rate limiting keys on the real client IP. See apps/api/src/main.ts.
TRUST_PROXY=1
