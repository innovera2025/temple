generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TempleStatus {
  active
  suspended
  archived

  @@map("temple_status")
}

enum ApplicationStatus {
  pending
  approved
  rejected

  @@map("application_status")
}

enum PlatformRole {
  super_admin
  support

  @@map("platform_role")
}

enum PersonnelType {
  monk
  novice
  staff

  @@map("personnel_type")
}

enum PersonnelStatus {
  active
  inactive

  @@map("personnel_status")
}

enum CeremonyType {
  merit
  funeral
  ordination
  housewarming
  robe_offering
  other

  @@map("ceremony_type")
}

enum CeremonyStatus {
  planned
  completed
  cancelled

  @@map("ceremony_status")
}

enum TenantRole {
  admin
  finance
  staff

  @@map("tenant_role")
}

enum DonorType {
  person
  organization

  @@map("donor_type")
}

enum DonationStatus {
  pledged
  confirmed
  cancelled

  @@map("donation_status")
}

enum DonationMethod {
  cash
  bank_transfer
  qr
  other

  @@map("donation_method")
}

enum ReceiptStatus {
  issued
  voided
  superseded

  @@map("receipt_status")
}

enum LedgerEntryStatus {
  draft
  posted
  voided

  @@map("ledger_entry_status")
}

enum LedgerAccountType {
  asset
  liability
  equity
  revenue
  expense

  @@map("ledger_account_type")
}

enum AttachmentOwnerType {
  donation
  receipt
  ledger_entry
  donor

  @@map("attachment_owner_type")
}

model Temple {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug              String             @unique
  nameTh            String             @map("name_th")
  nameEn            String?            @map("name_en")
  status            TempleStatus       @default(active)
  addressTh         String?            @map("address_th")
  subdistrict       String?
  district          String?
  province          String?
  postalCode        String?            @map("postal_code")
  phone             String?
  email             String?
  lineId            String?            @map("line_id")
  websiteUrl        String?            @map("website_url")
  abbotName         String?            @map("abbot_name")
  registrationNo    String?            @map("registration_no")
  taxId             String?            @map("tax_id")
  denomination      String?
  logoUrl           String?            @map("logo_url")
  receiptHeaderTh   String?            @map("receipt_header_th")
  receiptFooterTh   String?            @map("receipt_footer_th")
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime           @default(now()) @map("updated_at") @db.Timestamptz(6)
  users             User[]
  donors            Donor[]
  donations         Donation[]
  receipts          Receipt[]
  ledgerAccounts    LedgerAccount[]
  ledgerEntries     LedgerEntry[]
  reconciliationPeriods ReconciliationPeriod[]
  docCounters       DocCounter[]
  attachments       Attachment[]
  auditLogs         AuditLog[]
  refreshTokens     AuthRefreshToken[]
  applicationsCreated TempleApplication[] @relation("ApplicationCreatedTemple")
  breakGlassGrants  BreakGlassGrant[]
  personnel         Personnel[]
  ceremonies        Ceremony[]

  @@map("temples")
}

model PlatformUser {
  id           String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String             @unique
  displayName  String             @map("display_name")
  passwordHash String?            @map("password_hash")
  platformRole PlatformRole       @default(support) @map("platform_role")
  isActive     Boolean            @default(true) @map("is_active")
  createdAt    DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime           @default(now()) @map("updated_at") @db.Timestamptz(6)
  reviews      TempleApplication[]
  auditLogs    PlatformAuditLog[]
  refreshTokens PlatformRefreshToken[]
  breakGlassGrants BreakGlassGrant[]

  @@map("platform_users")
}

model TempleApplication {
  id                       String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  templeNameTh             String            @map("temple_name_th")
  contactEmail             String            @map("contact_email")
  status                   ApplicationStatus @default(pending)
  reviewedByPlatformUserId String?           @map("reviewed_by_platform_user_id") @db.Uuid
  reviewedByPlatformUser   PlatformUser?     @relation(fields: [reviewedByPlatformUserId], references: [id])
  reviewedAt               DateTime?         @map("reviewed_at") @db.Timestamptz(6)
  rejectionReason          String?           @map("rejection_reason")
  createdTempleId          String?           @map("created_temple_id") @db.Uuid
  createdTemple            Temple?           @relation("ApplicationCreatedTemple", fields: [createdTempleId], references: [id], onDelete: SetNull)
  createdAt                DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime          @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("temple_applications")
}

model PlatformRefreshToken {
  id                String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  platformUserId    String                @map("platform_user_id") @db.Uuid
  platformUser      PlatformUser          @relation(fields: [platformUserId], references: [id])
  tokenHash         String                @unique @map("token_hash")
  expiresAt         DateTime              @map("expires_at") @db.Timestamptz(6)
  revokedAt         DateTime?             @map("revoked_at") @db.Timestamptz(6)
  replacedByTokenId String?               @map("replaced_by_token_id") @db.Uuid
  replacedByToken   PlatformRefreshToken? @relation("PlatformRefreshTokenReplacement", fields: [replacedByTokenId], references: [id])
  replacesTokens    PlatformRefreshToken[] @relation("PlatformRefreshTokenReplacement")
  createdAt         DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([platformUserId])
  @@map("platform_refresh_tokens")
}

model BreakGlassGrant {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  platformUserId String       @map("platform_user_id") @db.Uuid
  platformUser   PlatformUser @relation(fields: [platformUserId], references: [id])
  tenantId       String       @map("tenant_id") @db.Uuid
  tenant         Temple       @relation(fields: [tenantId], references: [id])
  reason         String
  expiresAt      DateTime     @map("expires_at") @db.Timestamptz(6)
  revokedAt      DateTime?    @map("revoked_at") @db.Timestamptz(6)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([platformUserId])
  @@index([tenantId])
  @@map("break_glass_grants")
}

model PlatformAuditLog {
  id                  String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorPlatformUserId String?       @map("actor_platform_user_id") @db.Uuid
  actorPlatformUser   PlatformUser? @relation(fields: [actorPlatformUserId], references: [id])
  action              String
  entityType          String        @map("entity_type")
  entityId            String?       @map("entity_id") @db.Uuid
  metadata            Json          @default("{}")
  createdAt           DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("platform_audit_logs")
}

model User {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String     @map("tenant_id") @db.Uuid
  tenant      Temple     @relation(fields: [tenantId], references: [id])
  email       String     @unique
  passwordHash String?   @map("password_hash")
  displayName String     @map("display_name")
  role        TenantRole
  isActive    Boolean    @default(true) @map("is_active")
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime   @default(now()) @map("updated_at") @db.Timestamptz(6)
  auditLogs   AuditLog[]
  refreshTokens AuthRefreshToken[]

  @@unique([tenantId, email])
  @@unique([tenantId, id])
  @@index([tenantId])
  @@map("users")
}

model Donor {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String      @map("tenant_id") @db.Uuid
  tenant      Temple      @relation(fields: [tenantId], references: [id])
  displayName String      @map("display_name")
  legalName   String?     @map("legal_name")
  donorType   DonorType   @default(person) @map("donor_type")
  email       String?
  phone       String?
  lineId      String?     @map("line_id")
  address     String?
  taxId       String?     @map("tax_id")
  tags        String[]    @default([])
  notes       String?
  consent     Boolean     @default(false)
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime    @default(now()) @map("updated_at") @db.Timestamptz(6)
  donations   Donation[]

  @@index([tenantId])
  @@map("donors")
}

model Personnel {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String          @map("tenant_id") @db.Uuid
  tenant           Temple          @relation(fields: [tenantId], references: [id])
  personnelType    PersonnelType   @map("personnel_type")
  status           PersonnelStatus @default(active)
  displayName      String          @map("display_name")
  dharmaName       String?         @map("dharma_name")
  secularName      String?         @map("secular_name")
  rank             String?
  position         String?
  ordinationDate   DateTime?       @map("ordination_date") @db.Date
  ordinationTemple String?         @map("ordination_temple")
  preceptor        String?
  phansaCount      Int?            @map("phansa_count")
  dateOfBirth      DateTime?       @map("date_of_birth") @db.Date
  nationalId       String?         @map("national_id")
  phone            String?
  note             String?
  joinedAt         DateTime?       @map("joined_at") @db.Date
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime        @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@unique([tenantId, id])
  @@index([tenantId])
  @@index([tenantId, personnelType])
  @@map("personnel")
}

model Ceremony {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String         @map("tenant_id") @db.Uuid
  tenant         Temple         @relation(fields: [tenantId], references: [id])
  ceremonyType   CeremonyType   @map("ceremony_type")
  status         CeremonyStatus @default(planned)
  title          String
  ceremonyDate   DateTime       @map("ceremony_date") @db.Date
  timeNote       String?        @map("time_note")
  location       String?
  requesterName  String?        @map("requester_name")
  requesterPhone String?        @map("requester_phone")
  assignedMonks  String?        @map("assigned_monks")
  monkCount      Int?           @map("monk_count")
  note           String?
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime       @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@unique([tenantId, id])
  @@index([tenantId])
  @@index([tenantId, ceremonyDate])
  @@map("ceremonies")
}

model Donation {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String         @map("tenant_id") @db.Uuid
  tenant       Temple         @relation(fields: [tenantId], references: [id])
  donorId      String?        @map("donor_id") @db.Uuid
  donor        Donor?         @relation(fields: [donorId], references: [id])
  amountSatang BigInt         @map("amount_satang")
  currency     String         @default("THB") @db.Char(3)
  method       DonationMethod @default(cash)
  donationDate DateTime       @map("donation_date") @db.Date
  status       DonationStatus @default(confirmed)
  note         String?
  fundAccountId String?       @map("fund_account_id") @db.Uuid
  fundAccount  LedgerAccount? @relation(fields: [fundAccountId], references: [id])
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime       @default(now()) @map("updated_at") @db.Timestamptz(6)
  receipts     Receipt[]
  ledgerEntries LedgerEntry[]

  @@index([tenantId])
  @@map("donations")
}

model Receipt {
  id        String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String        @map("tenant_id") @db.Uuid
  tenant    Temple        @relation(fields: [tenantId], references: [id])
  donationId String       @map("donation_id") @db.Uuid
  donation  Donation      @relation(fields: [donationId], references: [id])
  receiptNo String        @map("receipt_no")
  status    ReceiptStatus @default(issued)
  issuedAt  DateTime      @default(now()) @map("issued_at") @db.Timestamptz(6)
  supersededByReceiptId String?  @map("superseded_by_receipt_id") @db.Uuid
  supersededBy          Receipt? @relation("ReceiptSupersession", fields: [supersededByReceiptId], references: [id])
  supersedes            Receipt[] @relation("ReceiptSupersession")
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime      @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@unique([tenantId, receiptNo])
  @@index([tenantId])
  @@map("receipts")
}

model LedgerAccount {
  id            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String            @map("tenant_id") @db.Uuid
  tenant        Temple            @relation(fields: [tenantId], references: [id])
  code          String
  nameTh        String            @map("name_th")
  accountType   LedgerAccountType @map("account_type")
  isActive      Boolean           @default(true) @map("is_active")
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime          @default(now()) @map("updated_at") @db.Timestamptz(6)
  ledgerEntries LedgerEntry[]
  fundedDonations Donation[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("ledger_accounts")
}

model LedgerEntry {
  id           String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String            @map("tenant_id") @db.Uuid
  tenant       Temple            @relation(fields: [tenantId], references: [id])
  entryNo      String            @map("entry_no")
  accountId    String            @map("account_id") @db.Uuid
  account      LedgerAccount     @relation(fields: [accountId], references: [id])
  amountSatang BigInt            @map("amount_satang")
  entryDate    DateTime          @map("entry_date") @db.Date
  status       LedgerEntryStatus @default(posted)
  description  String?
  payee        String?
  reconciledAt DateTime?         @map("reconciled_at") @db.Timestamptz(6)
  donationId   String?           @map("donation_id") @db.Uuid
  donation     Donation?         @relation(fields: [donationId], references: [id])
  createdAt    DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime          @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@unique([tenantId, entryNo])
  @@index([tenantId])
  @@index([tenantId, entryDate])
  @@index([donationId])
  @@map("ledger_entries")
}

model ReconciliationPeriod {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  tenant      Temple    @relation(fields: [tenantId], references: [id])
  periodStart DateTime  @map("period_start") @db.Date
  periodEnd   DateTime  @map("period_end") @db.Date
  closedAt    DateTime? @map("closed_at") @db.Timestamptz(6)
  closedByUserId String? @map("closed_by_user_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@unique([tenantId, periodStart, periodEnd])
  @@index([tenantId])
  @@map("reconciliation_periods")
}

model DocCounter {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  tenant    Temple   @relation(fields: [tenantId], references: [id])
  docType   String   @map("doc_type")
  nextValue BigInt   @default(1) @map("next_value")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@unique([tenantId, docType])
  @@index([tenantId])
  @@map("doc_counters")
}

model Attachment {
  id         String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String              @map("tenant_id") @db.Uuid
  tenant     Temple              @relation(fields: [tenantId], references: [id])
  ownerType  AttachmentOwnerType @map("owner_type")
  ownerId    String              @map("owner_id") @db.Uuid
  fileName   String              @map("file_name")
  mimeType   String              @map("mime_type")
  storageKey String              @map("storage_key")
  byteSize   BigInt              @map("byte_size")
  createdAt  DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([tenantId])
  @@map("attachments")
}

model AuditLog {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  tenant      Temple    @relation(fields: [tenantId], references: [id])
  actorUserId String?   @map("actor_user_id") @db.Uuid
  actorUser   User?     @relation(fields: [actorUserId], references: [id])
  action      String
  entityType  String    @map("entity_type")
  entityId    String?   @map("entity_id") @db.Uuid
  before      Json?
  after       Json?
  reason      String?
  ip          String?
  metadata    Json      @default("{}")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([tenantId])
  @@map("audit_logs")
}

model AuthRefreshToken {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String    @map("tenant_id") @db.Uuid
  tenant            Temple    @relation(fields: [tenantId], references: [id])
  userId            String    @map("user_id") @db.Uuid
  user              User      @relation(fields: [tenantId, userId], references: [tenantId, id])
  tokenHash         String    @unique @map("token_hash")
  expiresAt         DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt         DateTime? @map("revoked_at") @db.Timestamptz(6)
  replacedByTokenId String?   @map("replaced_by_token_id") @db.Uuid
  replacedByToken   AuthRefreshToken? @relation("RefreshTokenReplacement", fields: [tenantId, replacedByTokenId], references: [tenantId, id])
  replacesTokens    AuthRefreshToken[] @relation("RefreshTokenReplacement")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([tenantId, id])
  @@index([tenantId])
  @@index([tenantId, userId])
  @@map("auth_refresh_tokens")
}
