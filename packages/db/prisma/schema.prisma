generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TempleStatus {
  active
  suspended
  archived

  @@map("temple_status")
}

enum ApplicationStatus {
  pending
  approved
  rejected

  @@map("application_status")
}

enum PlatformRole {
  super_admin
  support

  @@map("platform_role")
}

enum PersonnelType {
  monk
  novice
  staff

  @@map("personnel_type")
}

enum PersonnelStatus {
  active
  inactive

  @@map("personnel_status")
}

enum CeremonyType {
  merit
  funeral
  ordination
  housewarming
  robe_offering
  other

  @@map("ceremony_type")
}

enum CeremonyStatus {
  requested
  planned
  completed
  cancelled

  @@map("ceremony_status")
}

enum InventoryCategory {
  sangha_offering
  supplies
  equipment
  other

  @@map("inventory_category")
}

enum InventoryStatus {
  active
  inactive

  @@map("inventory_status")
}

enum InventoryMovementType {
  receive
  issue

  @@map("inventory_movement_type")
}

enum TenantRole {
  admin
  finance
  staff

  @@map("tenant_role")
}

enum DonorType {
  person
  organization

  @@map("donor_type")
}

enum DonationStatus {
  pledged
  confirmed
  cancelled

  @@map("donation_status")
}

enum DonationMethod {
  cash
  bank_transfer
  qr
  other

  @@map("donation_method")
}

enum ReceiptStatus {
  issued
  voided
  superseded

  @@map("receipt_status")
}

enum LedgerEntryStatus {
  draft
  posted
  voided

  @@map("ledger_entry_status")
}

enum LedgerAccountType {
  asset
  liability
  equity
  revenue
  expense

  @@map("ledger_account_type")
}

enum AttachmentOwnerType {
  donation
  receipt
  ledger_entry
  donor
  item_loan

  @@map("attachment_owner_type")
}

enum LoanStatus {
  requested
  borrowed
  returned
  cancelled

  @@map("loan_status")
}

enum LoanSettlementType {
  replacement
  cash

  @@map("loan_settlement_type")
}

model Temple {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug              String             @unique
  nameTh            String             @map("name_th")
  nameEn            String?            @map("name_en")
  status            TempleStatus       @default(active)
  addressTh         String?            @map("address_th")
  subdistrict       String?
  district          String?
  province          String?
  postalCode        String?            @map("postal_code")
  phone             String?
  email             String?
  lineId            String?            @map("line_id")
  websiteUrl        String?            @map("website_url")
  abbotName         String?            @map("abbot_name")
  registrationNo    String?            @map("registration_no")
  taxId             String?            @map("tax_id")
  denomination      String?
  logoUrl           String?            @map("logo_url")
  receiptHeaderTh   String?            @map("receipt_header_th")
  receiptFooterTh   String?            @map("receipt_footer_th")
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime           @default(now()) @map("updated_at") @db.Timestamptz(6)
  users             User[]
  donors            Donor[]
  donations         Donation[]
  receipts          Receipt[]
  ledgerAccounts    LedgerAccount[]
  ledgerEntries     LedgerEntry[]
  reconciliationPeriods ReconciliationPeriod[]
  docCounters       DocCounter[]
  attachments       Attachment[]
  auditLogs         AuditLog[]
  refreshTokens     AuthRefreshToken[]
  applicationsCreated TempleApplication[] @relation("ApplicationCreatedTemple")
  breakGlassGrants  BreakGlassGrant[]
  personnel         Personnel[]
  ceremonies        Ceremony[]
  templeHalls       TempleHall[]
  inventoryItems    InventoryItem[]
  inventoryMovements InventoryMovement[]
  storageRooms      StorageRoom[]
  borrowableItems   BorrowableItem[]
  itemLoans         ItemLoan[]
  itemLoanSettlements ItemLoanSettlement[]

  @@map("temples")
}

model PlatformUser {
  id           String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String             @unique
  displayName  String             @map("display_name")
  passwordHash String?            @map("password_hash")
  platformRole PlatformRole       @default(support) @map("platform_role")
  isActive     Boolean            @default(true) @map("is_active")
  createdAt    DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime           @default(now()) @map("updated_at") @db.Timestamptz(6)
  reviews      TempleApplication[]
  auditLogs    PlatformAuditLog[]
  refreshTokens PlatformRefreshToken[]
  breakGlassGrants BreakGlassGrant[]

  @@map("platform_users")
}

model TempleApplication {
  id                       String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  templeNameTh             String            @map("temple_name_th")
  contactEmail             String            @map("contact_email")
  status                   ApplicationStatus @default(pending)
  reviewedByPlatformUserId String?           @map("reviewed_by_platform_user_id") @db.Uuid
  reviewedByPlatformUser   PlatformUser?     @relation(fields: [reviewedByPlatformUserId], references: [id])
  reviewedAt               DateTime?         @map("reviewed_at") @db.Timestamptz(6)
  rejectionReason          String?           @map("rejection_reason")
  createdTempleId          String?           @map("created_temple_id") @db.Uuid
  createdTemple            Temple?           @relation("ApplicationCreatedTemple", fields: [createdTempleId], references: [id], onDelete: SetNull)
  createdAt                DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime          @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("temple_applications")
}

// Devotee (ญาติโยม) self-service identity — tenant-INDEPENDENT (no tenantId), its
// own auth plane. Mirrors PlatformUser. The selected temple is chosen per request.
model DevoteeAccount {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String   @unique
  displayName  String   @map("display_name")
  passwordHash String?  @map("password_hash")
  phone        String?
  isActive     Boolean  @default(true) @map("is_active")
  emailVerifiedAt DateTime? @map("email_verified_at") @db.Timestamptz(6)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  donors        Donor[]
  refreshTokens DevoteeRefreshToken[]
  ceremonies    Ceremony[]
  itemLoans     ItemLoan[]

  @@map("devotee_accounts")
}

/// Single-use, hashed action tokens for account recovery / email verification.
/// Plane-agnostic (staff user OR devotee account, exactly one set) — accessed
/// only via withSystemAccess; never tenant-scoped, never returned raw.
model AuthActionToken {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  purpose          String
  tokenHash        String    @unique @map("token_hash")
  userId           String?   @map("user_id") @db.Uuid
  devoteeAccountId String?   @map("devotee_account_id") @db.Uuid
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt           DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId])
  @@index([devoteeAccountId])
  @@map("auth_action_tokens")
}

model DevoteeRefreshToken {
  id                String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  devoteeAccountId  String               @map("devotee_account_id") @db.Uuid
  devoteeAccount    DevoteeAccount       @relation(fields: [devoteeAccountId], references: [id])
  tokenHash         String               @unique @map("token_hash")
  expiresAt         DateTime             @map("expires_at") @db.Timestamptz(6)
  revokedAt         DateTime?            @map("revoked_at") @db.Timestamptz(6)
  replacedByTokenId String?              @map("replaced_by_token_id") @db.Uuid
  replacedByToken   DevoteeRefreshToken? @relation("DevoteeRefreshTokenReplacement", fields: [replacedByTokenId], references: [id])
  replacesTokens    DevoteeRefreshToken[] @relation("DevoteeRefreshTokenReplacement")
  createdAt         DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([devoteeAccountId])
  @@map("devotee_refresh_tokens")
}

model PlatformRefreshToken {
  id                String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  platformUserId    String                @map("platform_user_id") @db.Uuid
  platformUser      PlatformUser          @relation(fields: [platformUserId], references: [id])
  tokenHash         String                @unique @map("token_hash")
  expiresAt         DateTime              @map("expires_at") @db.Timestamptz(6)
  revokedAt         DateTime?             @map("revoked_at") @db.Timestamptz(6)
  replacedByTokenId String?               @map("replaced_by_token_id") @db.Uuid
  replacedByToken   PlatformRefreshToken? @relation("PlatformRefreshTokenReplacement", fields: [replacedByTokenId], references: [id])
  replacesTokens    PlatformRefreshToken[] @relation("PlatformRefreshTokenReplacement")
  createdAt         DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([platformUserId])
  @@map("platform_refresh_tokens")
}

model BreakGlassGrant {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  platformUserId String       @map("platform_user_id") @db.Uuid
  platformUser   PlatformUser @relation(fields: [platformUserId], references: [id])
  tenantId       String       @map("tenant_id") @db.Uuid
  tenant         Temple       @relation(fields: [tenantId], references: [id])
  reason         String
  expiresAt      DateTime     @map("expires_at") @db.Timestamptz(6)
  revokedAt      DateTime?    @map("revoked_at") @db.Timestamptz(6)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([platformUserId])
  @@index([tenantId])
  @@map("break_glass_grants")
}

model PlatformAuditLog {
  id                  String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorPlatformUserId String?       @map("actor_platform_user_id") @db.Uuid
  actorPlatformUser   PlatformUser? @relation(fields: [actorPlatformUserId], references: [id])
  action              String
  entityType          String        @map("entity_type")
  entityId            String?       @map("entity_id") @db.Uuid
  metadata            Json          @default("{}")
  createdAt           DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("platform_audit_logs")
}

model User {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String     @map("tenant_id") @db.Uuid
  tenant      Temple     @relation(fields: [tenantId], references: [id])
  email       String     @unique
  passwordHash String?   @map("password_hash")
  displayName String     @map("display_name")
  role        TenantRole
  isActive    Boolean    @default(true) @map("is_active")
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime   @default(now()) @map("updated_at") @db.Timestamptz(6)
  auditLogs   AuditLog[]
  refreshTokens AuthRefreshToken[]

  @@unique([tenantId, email])
  @@unique([tenantId, id])
  @@index([tenantId])
  @@map("users")
}

model Donor {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String      @map("tenant_id") @db.Uuid
  tenant      Temple      @relation(fields: [tenantId], references: [id])
  displayName String      @map("display_name")
  legalName   String?     @map("legal_name")
  donorType   DonorType   @default(person) @map("donor_type")
  email       String?
  phone       String?
  lineId      String?     @map("line_id")
  address     String?
  taxId       String?     @map("tax_id")
  tags        String[]    @default([])
  notes       String?
  consent     Boolean     @default(false)
  devoteeAccountId String?  @map("devotee_account_id") @db.Uuid
  devoteeAccount   DevoteeAccount? @relation(fields: [devoteeAccountId], references: [id])
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime    @default(now()) @map("updated_at") @db.Timestamptz(6)
  donations   Donation[]

  @@unique([tenantId, devoteeAccountId])
  @@index([tenantId])
  @@map("donors")
}

model Personnel {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String          @map("tenant_id") @db.Uuid
  tenant           Temple          @relation(fields: [tenantId], references: [id])
  personnelType    PersonnelType   @map("personnel_type")
  status           PersonnelStatus @default(active)
  displayName      String          @map("display_name")
  dharmaName       String?         @map("dharma_name")
  secularName      String?         @map("secular_name")
  rank             String?
  position         String?
  ordinationDate   DateTime?       @map("ordination_date") @db.Date
  ordinationTemple String?         @map("ordination_temple")
  preceptor        String?
  phansaCount      Int?            @map("phansa_count")
  dateOfBirth      DateTime?       @map("date_of_birth") @db.Date
  nationalId       String?         @map("national_id")
  phone            String?
  note             String?
  joinedAt         DateTime?       @map("joined_at") @db.Date
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime        @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@unique([tenantId, id])
  @@index([tenantId])
  @@index([tenantId, personnelType])
  @@map("personnel")
}

model Ceremony {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String         @map("tenant_id") @db.Uuid
  tenant         Temple         @relation(fields: [tenantId], references: [id])
  ceremonyType   CeremonyType   @map("ceremony_type")
  status         CeremonyStatus @default(planned)
  title          String
  ceremonyDate   DateTime       @map("ceremony_date") @db.Date
  timeNote       String?        @map("time_note")
  location       String?
  /// Booked hall — tenant-scoped composite FK lives in the migration SQL.
  hallId         String?        @map("hall_id") @db.Uuid
  requesterName  String?        @map("requester_name")
  requesterPhone String?        @map("requester_phone")
  assignedMonks  String?        @map("assigned_monks")
  monkCount      Int?           @map("monk_count")
  note           String?
  isPublic       Boolean        @default(false) @map("is_public")
  devoteeAccountId String?        @map("devotee_account_id") @db.Uuid
  devoteeAccount   DevoteeAccount? @relation(fields: [devoteeAccountId], references: [id])
  invitedMonks   CeremonyMonk[]
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime       @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@unique([tenantId, id])
  @@index([tenantId])
  @@index([tenantId, ceremonyDate])
  @@index([tenantId, hallId, ceremonyDate])
  @@index([devoteeAccountId])
  @@map("ceremonies")
}

model TempleHall {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  tenant    Temple   @relation(fields: [tenantId], references: [id])
  name      String
  capacity  Int?
  note      String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@unique([tenantId, id])
  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("temple_halls")
}

model CeremonyMonk {
  tenantId    String   @map("tenant_id") @db.Uuid
  ceremonyId  String   @map("ceremony_id") @db.Uuid
  ceremony    Ceremony @relation(fields: [ceremonyId], references: [id], onDelete: Cascade)
  personnelId String   @map("personnel_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@id([ceremonyId, personnelId])
  @@index([tenantId])
  @@index([tenantId, personnelId])
  @@map("ceremony_monks")
}

model InventoryItem {
  id        String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String              @map("tenant_id") @db.Uuid
  tenant    Temple              @relation(fields: [tenantId], references: [id])
  name      String
  category  InventoryCategory   @default(other)
  unit      String?
  quantity  Int                 @default(0)
  status    InventoryStatus     @default(active)
  note      String?
  roomId    String?             @map("room_id") @db.Uuid
  room      StorageRoom?        @relation(fields: [tenantId, roomId], references: [tenantId, id])
  movements InventoryMovement[]
  createdAt DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime            @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@unique([tenantId, id])
  @@index([tenantId])
  @@index([tenantId, category])
  @@index([tenantId, roomId])
  @@map("inventory_items")
}

model StorageRoom {
  id        String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String          @map("tenant_id") @db.Uuid
  tenant    Temple          @relation(fields: [tenantId], references: [id])
  name      String
  note      String?
  items     InventoryItem[]
  createdAt DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime        @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@unique([tenantId, id])
  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("storage_rooms")
}

model InventoryMovement {
  id           String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String                @map("tenant_id") @db.Uuid
  tenant       Temple                @relation(fields: [tenantId], references: [id])
  itemId       String                @map("item_id") @db.Uuid
  item         InventoryItem         @relation(fields: [tenantId, itemId], references: [tenantId, id])
  movementType InventoryMovementType @map("movement_type")
  quantity     Int
  balanceAfter Int                   @map("balance_after")
  movementDate DateTime              @map("movement_date") @db.Date
  reason       String?
  reference    String?
  note         String?
  createdAt    DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([tenantId])
  @@index([tenantId, itemId])
  @@map("inventory_movements")
}

model BorrowableItem {
  id        String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String            @map("tenant_id") @db.Uuid
  tenant    Temple            @relation(fields: [tenantId], references: [id])
  name      String
  category  InventoryCategory @default(equipment)
  unit      String?
  totalQty  Int               @default(0) @map("total_qty")
  status    InventoryStatus   @default(active)
  note      String?
  loans     ItemLoan[]
  createdAt DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime          @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@unique([tenantId, id])
  @@index([tenantId])
  @@map("borrowable_items")
}

model ItemLoan {
  id            String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String               @map("tenant_id") @db.Uuid
  tenant        Temple               @relation(fields: [tenantId], references: [id])
  loanNo        String               @map("loan_no")
  itemId        String               @map("item_id") @db.Uuid
  item          BorrowableItem       @relation(fields: [tenantId, itemId], references: [tenantId, id])
  borrowerName  String               @map("borrower_name")
  borrowerPhone String?              @map("borrower_phone")
  quantity      Int
  borrowedAt    DateTime             @map("borrowed_at") @db.Date
  dueAt         DateTime?            @map("due_at") @db.Date
  borrowPhotoId String?              @map("borrow_photo_id") @db.Uuid
  borrowPhotoIds Json?               @map("borrow_photo_ids")
  status        LoanStatus           @default(borrowed)
  returnedAt    DateTime?            @map("returned_at") @db.Date
  returnedQty   Int?                 @map("returned_qty")
  returnPhotoIds Json?                @map("return_photo_ids")
  returnNote    String?              @map("return_note")
  note          String?
  devoteeAccountId String?           @map("devotee_account_id") @db.Uuid
  devoteeAccount   DevoteeAccount?   @relation(fields: [devoteeAccountId], references: [id])
  settlements   ItemLoanSettlement[]
  createdAt     DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime             @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@unique([tenantId, loanNo])
  @@unique([tenantId, id])
  @@index([tenantId])
  @@index([tenantId, itemId])
  @@index([tenantId, status])
  @@index([devoteeAccountId])
  @@map("item_loans")
}

model ItemLoanSettlement {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String             @map("tenant_id") @db.Uuid
  tenant           Temple             @relation(fields: [tenantId], references: [id])
  loanId           String             @map("loan_id") @db.Uuid
  loan             ItemLoan           @relation(fields: [tenantId, loanId], references: [tenantId, id])
  shortageQty      Int                @map("shortage_qty")
  settlementType   LoanSettlementType @map("settlement_type")
  cashAmountSatang BigInt?            @map("cash_amount_satang")
  replacementNote  String?            @map("replacement_note")
  settledAt        DateTime           @map("settled_at") @db.Date
  note             String?
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([tenantId])
  @@index([tenantId, loanId])
  @@map("item_loan_settlements")
}

model Donation {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String         @map("tenant_id") @db.Uuid
  tenant       Temple         @relation(fields: [tenantId], references: [id])
  donorId      String?        @map("donor_id") @db.Uuid
  donor        Donor?         @relation(fields: [donorId], references: [id])
  amountSatang BigInt         @map("amount_satang")
  currency     String         @default("THB") @db.Char(3)
  method       DonationMethod @default(cash)
  donationDate DateTime       @map("donation_date") @db.Date
  status       DonationStatus @default(confirmed)
  note         String?
  fundAccountId String?       @map("fund_account_id") @db.Uuid
  fundAccount  LedgerAccount? @relation(fields: [fundAccountId], references: [id])
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime       @default(now()) @map("updated_at") @db.Timestamptz(6)
  receipts     Receipt[]
  ledgerEntries LedgerEntry[]

  @@index([tenantId])
  @@map("donations")
}

model Receipt {
  id        String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String        @map("tenant_id") @db.Uuid
  tenant    Temple        @relation(fields: [tenantId], references: [id])
  donationId String       @map("donation_id") @db.Uuid
  donation  Donation      @relation(fields: [donationId], references: [id])
  receiptNo String        @map("receipt_no")
  status    ReceiptStatus @default(issued)
  issuedAt  DateTime      @default(now()) @map("issued_at") @db.Timestamptz(6)
  supersededByReceiptId String?  @map("superseded_by_receipt_id") @db.Uuid
  supersededBy          Receipt? @relation("ReceiptSupersession", fields: [supersededByReceiptId], references: [id])
  supersedes            Receipt[] @relation("ReceiptSupersession")
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime      @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@unique([tenantId, receiptNo])
  @@index([tenantId])
  @@map("receipts")
}

model LedgerAccount {
